{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "markitdown-cf",
  "main": "src/index.ts",
  "compatibility_date": "2025-10-03",
  "containers": [
    {
      "class_name": "MyContainer",
      "image": "./Dockerfile",
      "instance_type": "basic",
      "max_instances": 2,
    },
  ],
  "durable_objects": {
    "bindings": [
      {
        "name": "MY_CONTAINER",
        "class_name": "MyContainer",
      },
    ],
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["MyContainer"],
    },
  ],
  "observability": {
    "enabled": true,
  },
}
